# AeroML Backend Environment Variables
# COMPLETE - NOTHING SKIPPED

# ─── DATABASE ────────────────────────────────────────────────────────────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_database_password
POSTGRES_DB=aeroml_v6
POSTGRES_HOST=localhost

# ─── SECURITY ────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secure_random_secret_key_here
ADMIN_PASSWORD=your_secure_admin_password_here

# ─── EMAIL (Resend) ─────────────────────────────────────────────────────

RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# ─── PAYMENTS (Dodo) ────────────────────────────────────────────────────

DODO_SECRET_KEY=your_dodo_secret_key_here
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret_here
DODO_PRODUCT_ID=premium_monthly

# ─── REDIS ──────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ─── FRONTEND URL ──────────────────────────────────────────────────────

FRONTEND_URL=http://localhost:3000

# ─── ADMIN EMAILS (HARDCODED) ──────────────────────────────────────────

ADMIN_EMAIL_1=moddedgames200@gmail.com
